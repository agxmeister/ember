    <string name="trends_readout_week_avg">MEDIA 14 SETT.</string>
    <string name="trends_avg_info_daily">È una media a 14 giorni che combina le tue pesate recenti, attenuando gli alti e bassi giornalieri così da vedere il tuo peso reale invece del rumore di oggi.</string>
    <string name="trends_avg_info_weekly">È una media a 14 settimane che combina le tue pesate recenti, attenuando le oscillazioni settimanali così da vedere il tuo peso reale invece del rumore di questa settimana.</string>
    <string name="trends_readout_wk_prefix">SETT.</string>
    <string name="trends_day_and_time">giorno e ora</string>
    <string name="trends_tap_to_change">tocca per modificare</string>
    <string name="trends_taken_at">rilevato alle</string>
    <string name="trends_streak">SERIE</string>
    <string name="trends_streak_info_daily">La tua serie conta per quanti giorni consecutivi la tendenza del tuo peso si è mossa verso il tuo obiettivo.</string>
    <string name="trends_streak_info_weekly">La tua serie conta per quante settimane consecutive la tendenza del tuo peso si è mossa verso il tuo obiettivo.</string>
