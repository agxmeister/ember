    <!-- Trends / Equalizer -->
    <string name="trends_tgt_prefix">OB.</string>
    <string name="trends_delta_target">Δ TENDENZA</string>
    <string name="trends_trend_pending_info">La tua tendenza settimanale appare quando Ember ha abbastanza misurazioni. Registrane altre %1$d per vedere quanto velocemente stai progredendo.</string>
    <string name="trends_trend_info">La tendenza mostra quanto velocemente il tuo peso medio cambia ogni settimana. ▼ significa che sta calando, ▲ che sta salendo.</string>
    <string name="trends_tap_to_edit">TOCCA PER MODIFICARE</string>
